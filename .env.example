# ─────────────────────────────────────────
# Canvas LMS
# ─────────────────────────────────────────
CANVAS_BASE_URL=https://tuinstancia.instructure.com
CANVAS_ACCESS_TOKEN=tu_token_canvas_aqui
# ID de la cuenta raíz en Canvas (normalmente 1)
CANVAS_ACCOUNT_ID=1

# ─────────────────────────────────────────
# Microsoft Entra / Azure AD
# ─────────────────────────────────────────
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=tu_secreto_azure_aqui
# SKU de licencias — ajustar al nombre exacto que aparece en /subscribedSkus del tenant
# Valores comunes: STANDARDWOFFPACK_STUDENT, M365_A1_FOR_STUDENTS, ENTERPRISEPACK
AZURE_SKU_STUDENTS=STANDARDWOFFPACK_STUDENT
# Valores comunes: STANDARDWOFFPACK_FACULTY, M365_A1_FACULTY, ENTERPRISEPACK
AZURE_SKU_TEACHERS=STANDARDWOFFPACK_FACULTY

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
PORT=3000
ENVIRONMENT=development

# ─────────────────────────────────────────
# Dominio institucional & credenciales
# ─────────────────────────────────────────
# Dominio para generar emails: nombre.apellido@DOMINIO
INSTITUTIONAL_DOMAIN=usil.edu.py
# Código de país para Azure AD (ISO 3166-1 alpha-2)
USAGE_LOCATION=PY
# URL de acceso a Microsoft Teams
TEAMS_URL=https://teams.microsoft.com

# ─────────────────────────────────────────
# SMTP (para envío de correo de bienvenida)
# Dejar vacío para desactivar el envío
# ─────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=notificaciones@usil.edu.py
SMTP_PASSWORD=tu_password_smtp
SMTP_FROM=no-reply@usil.edu.py
